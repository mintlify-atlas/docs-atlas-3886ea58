  "keyFeatures": [
    "Plugin architecture with channels, providers, and tools",
    "Self-improving adaptive memory with episodic storage and temporal decay",
    "Heartware personality system with SOUL.md and IDENTITY.md",
    "Smart routing with 8-dimension query classification",
    "Sub-agent delegation with autonomous orchestration",
    "SHIELD.md runtime enforcement for security",
    "4-layer context compaction pipeline",
    "Discord-like web UI with SSE streaming",
    "Bun-native runtime for performance",
    "Built-in Ollama Cloud provider with free tier"
  ],
  "publicApiSurface": [
    "tinyclaw CLI (setup, start, config, backup, purge, seed)",
    "@tinyclaw/core - Core agent runtime and loop",
    "@tinyclaw/types - TypeScript interfaces and types",
    "@tinyclaw/config - Configuration management",
    "@tinyclaw/heartware - Personality and self-configuration system",
    "@tinyclaw/memory - Adaptive memory engine (episodic + FTS5)",
    "@tinyclaw/delegation - Sub-agent orchestration",
    "@tinyclaw/router - Multi-provider LLM routing",
    "@tinyclaw/compactor - Context compaction engine",
    "@tinyclaw/shield - Runtime SHIELD.md enforcement",
    "@tinyclaw/learning - Behavioral pattern detection",
    "@tinyclaw/sandbox - Bun Worker code execution",
    "@tinyclaw/shell - Controlled shell execution",
    "@tinyclaw/secrets - Encrypted secrets management",
    "@tinyclaw/plugins - Plugin discovery and loading",
    "@tinyclaw/logger - Singleton logger",
    "@tinyclaw/intercom - Pub/sub inter-agent communication",
    "@tinyclaw/queue - Per-session message locking queue",
    "ChannelPlugin interface",
